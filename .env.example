# Скопируй в .env и при необходимости измени:
#   cp .env.example .env
#
# Docker Compose подхватывает .env из этой папки автоматически.

POSTGRES_DB=bdsnowflake
POSTGRES_USER=bdsnowflake
POSTGRES_PASSWORD=bdsnowflake

# Порт на хосте (внутри контейнера всегда 5432)
POSTGRES_PORT=5432

# Имя контейнера (опционально)
POSTGRES_CONTAINER_NAME=bdsnowflake-postgres
